{
  "name": "n8n-nodes-shipstation",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for ShipStation providing 15 resources and 80+ operations for e-commerce shipping automation including order management, multi-carrier label creation, rate shopping, and inventory management.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-shipstation.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-shipstation#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-shipstation/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "shipstation",
    "shipping",
    "ecommerce",
    "fulfillment",
    "labels",
    "carriers",
    "tracking",
    "inventory",
    "warehouse",
    "orders",
    "ups",
    "fedex",
    "usps",
    "dhl"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ShipStationApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ShipStation/ShipStation.node.js",
      "dist/nodes/ShipStation/ShipStationTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.35.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
